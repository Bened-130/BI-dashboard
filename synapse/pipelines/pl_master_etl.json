{
  "name": "pl_master_etl",
  "properties": {
    "activities": [
      {
        "name": "Bronze Ingestion",
        "type": "ExecutePipeline",
        "dependsOn": [],
        "typeProperties": {
          "pipeline": {
            "referenceName": "pl_bronze_ingest",
            "type": "PipelineReference"
          },
          "waitOnCompletion": true
        }
      },
      {
        "name": "Data Quality Check - Bronze",
        "type": "ExecutePipeline",
        "dependsOn": [
          {
            "activity": "Bronze Ingestion",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "pipeline": {
            "referenceName": "pl_data_quality_checks",
            "type": "PipelineReference"
          },
          "parameters": {
            "layer": "bronze"
          }
        }
      },
      {
        "name": "Silver Transformation",
        "type": "ExecutePipeline",
        "dependsOn": [
          {
            "activity": "Data Quality Check - Bronze",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "pipeline": {
            "referenceName": "pl_silver_transform",
            "type": "PipelineReference"
          }
        }
      },
      {
        "name": "Gold Analytics",
        "type": "ExecutePipeline",
        "dependsOn": [
          {
            "activity": "Silver Transformation",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "pipeline": {
            "referenceName": "pl_gold_analytics",
            "type": "PipelineReference"
          }
        }
      },
      {
        "name": "Send Success Notification",
        "type": "WebActivity",
        "dependsOn": [
          {
            "activity": "Gold Analytics",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "url": "https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK",
          "method": "POST",
          "body": {
            "text": "✅ ETL Pipeline completed successfully for @{pipeline().parameters.trigger_date}"
          }
        }
      }
    ],
    "parameters": {
      "trigger_date": {
        "type": "string",
        "defaultValue": "@utcnow()"
      }
    },
    "variables": {
      "pipeline_status": {
        "type": "String",
        "defaultValue": "Running"
      }
    }
  }
}